{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "kendo-cli://schemas/KendoComponent.json",
    "title": "Schema for valid kendo component names",

    "definitions": {

        "componentName": {
            "type": "string",
            "enum": [
                "appbar",
                "autocomplete",
                "avatar",
                "badge",
                "bottomnav",
                "breadcrumb",
                "button",
                "calendar",
                "card",
                "chat",
                "checkbox",
                "chip",
                "colorpicker",
                "combobox",
                "dataviz",
                "dateinput",
                "datepicker",
                "daterangepicker",
                "datetimepicker",
                "dialog",
                "drawer",
                "dropdowngrid",
                "dropdownlist",
                "dropdowntree",
                "editor",
                "expander",
                "fab",
                "filemanager",
                "filter",
                "floatinglabel",
                "form",
                "gantt",
                "grid",
                "imageeditor",
                "input",
                "label",
                "listbox",
                "listview",
                "loader",
                "map",
                "maskedtextbox",
                "mediaplayer",
                "menu",
                "multiselect",
                "notification",
                "numerictextbox",
                "pager",
                "panelbar",
                "pivotgrid",
                "progressbar",
                "radio",
                "rating",
                "scheduler",
                "scrollview",
                "slider",
                "splitter",
                "spreadsheet",
                "stepper",
                "switch",
                "tabstrip",
                "textarea",
                "textbox",
                "tilelayout",
                "timeline",
                "timepicker",
                "toolbar",
                "tooltip",
                "treelist",
                "treeview",
                "upload",
                "window",
                "wizard"
            ]
        },

        "componentList": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/componentName"
            },
            "uniqueItems": true
        }

    }
}
